{
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "opus",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat \"$HOME/.claude/skill-first-reminder.txt\"",
            "timeout": 5,
            "statusMessage": "skill-first check"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"$HOME/.claude/skills/scripts/claude-sync.sh\" pull 2>/dev/null || true",
            "timeout": 20,
            "statusMessage": "sync claude-skills (pull)"
          },
          {
            "type": "command",
            "shell": "powershell",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"$HOME/.claude/skills/scripts/claude-sync.ps1\" pull",
            "timeout": 20,
            "statusMessage": "sync claude-skills (pull)"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"$HOME/.claude/skills/scripts/claude-sync.sh\" check 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "check config drift"
          },
          {
            "type": "command",
            "shell": "powershell",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"$HOME/.claude/skills/scripts/claude-sync.ps1\" check",
            "timeout": 10,
            "statusMessage": "check config drift"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "theme": "dark"
}
